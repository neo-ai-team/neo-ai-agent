{
    "version": 2,
    "builds": [
        {
            "src": "app/api/**/*.ts",
            "use": "@vercel/node"
        }
    ],
    "routes": [
        {
            "src": "/api/ping",
            "dest": "/app/api/ping/route.js"
        },
        {
            "src": "/api/messages",
            "dest": "/app/api/messages/route.js"
        }
    ]
}